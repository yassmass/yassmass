#!/usr/bin/env ruby
# frozen_string_literal: true

require "fileutils"
require "open3"
require "pathname"
require "tmpdir"
require "yaml"
require "date"

ROOT = Pathname.new(File.expand_path("..", __dir__))
PDF_DIR = ROOT.join("assets/pdfs")
RENDER_ROOT = ROOT.join("assets/pdf-renders")
DATA_PATH = ROOT.join("_data/pdf_documents.yml")
RENDER_DPI = ENV.fetch("PDF_RENDER_DPI", "144")
SECTIONS = %w[applications automation consultancy product].freeze

def command_path(name)
  ENV.fetch("PATH", "").split(File::PATH_SEPARATOR).each do |dir|
    path = File.join(dir, name)
    return path if File.executable?(path) && !File.directory?(path)
  end

  abort "Missing required command: #{name}"
end

PDFINFO = ENV["PDFINFO"] || command_path("pdfinfo")
PDFTOPPM = ENV["PDFTOPPM"] || command_path("pdftoppm")

def relative_asset_path(path)
  "/" + Pathname.new(path).relative_path_from(ROOT).to_s
end

def front_matter(path)
  text = File.read(path, encoding: "UTF-8")
  return nil unless text.start_with?("---\n")

  yaml = text.split(/^---\s*$/, 3)[1]
  YAML.safe_load(yaml, permitted_classes: [Date], aliases: false)
end

def pdf_page_count(pdf_path)
  stdout, stderr, status = Open3.capture3(PDFINFO, pdf_path.to_s)
  abort "pdfinfo failed for #{pdf_path}:\n#{stderr}" unless status.success?
  abort "Encrypted PDFs are not supported: #{pdf_path}" if stdout.match?(/^Encrypted:\s+yes$/i)

  pages = stdout[/^Pages:\s+(\d+)$/i, 1]
  abort "Could not determine page count for #{pdf_path}" unless pages

  pages.to_i
end

def render_pdf(pdf_path, target_dir, expected_pages)
  FileUtils.mkdir_p(target_dir)
  Dir[target_dir.join("page-*.png")].each { |file| FileUtils.rm_f(file) }

  prefix = target_dir.join("page")
  _, stderr, status = Open3.capture3(PDFTOPPM, "-png", "-r", RENDER_DPI, pdf_path.to_s, prefix.to_s)
  abort "pdftoppm failed for #{pdf_path}:\n#{stderr}" unless status.success?

  pages = Dir[target_dir.join("page-*.png")].sort
  abort "Expected #{expected_pages} rendered pages for #{pdf_path}, got #{pages.length}" unless pages.length == expected_pages

  pages.each do |page|
    abort "Rendered page is empty: #{page}" unless File.size(page).positive?
  end

  pages
end

def copy_rendered_pages(source_pages, target_dir)
  FileUtils.mkdir_p(target_dir)
  Dir[target_dir.join("page-*.png")].each { |file| FileUtils.rm_f(file) }

  source_pages.each_with_index do |source_page, index|
    FileUtils.cp(source_page, target_dir.join(format("page-%02d.png", index + 1)))
  end

  pages = Dir[target_dir.join("page-*.png")].sort
  abort "Copied page count mismatch for #{target_dir}" unless pages.length == source_pages.length

  pages.each do |page|
    abort "Copied page is empty: #{page}" unless File.size(page).positive?
  end

  pages
end

def normalized_pdf_path(raw_path)
  abort "Missing pdf front matter value" if raw_path.to_s.strip.empty?

  path = raw_path.to_s.sub(%r{\A/}, "")
  pdf_path = ROOT.join(path)
  abort "PDF does not exist: #{raw_path}" unless pdf_path.file?
  abort "PDF must live under assets/pdfs: #{raw_path}" unless pdf_path.to_s.start_with?(PDF_DIR.to_s + File::SEPARATOR)

  pdf_path
end

def showcase_pages
  SECTIONS.flat_map { |section| Dir[ROOT.join(section, "**/*.md")] }.map do |path|
    data = front_matter(path)
    next unless data && data["layout"] == "pdf-showcase"

    permalink = data.fetch("permalink")
    render_key = data["render_key"].to_s
    abort "Missing render_key in #{path}" if render_key.empty?
    abort "render_key must not start with slash in #{path}" if render_key.start_with?("/")
    abort "render_key must match permalink path in #{path}" unless permalink.to_s.delete_prefix("/").delete_suffix("/") == render_key

    pdf_path = normalized_pdf_path(data["pdf"])

    {
      source: path,
      key: render_key,
      title: data["document_title"] || data["title"],
      section: data["section"],
      pdf_path: pdf_path,
      pdf_url: relative_asset_path(pdf_path)
    }
  end.compact
end

def all_pdf_paths
  Dir[PDF_DIR.join("**/*.pdf")].map { |path| Pathname.new(path) }.sort
end

routes = showcase_pages
abort "No pdf-showcase pages found" if routes.empty?

pdfs = all_pdf_paths
abort "No PDFs found in #{PDF_DIR}" if pdfs.empty?

FileUtils.rm_rf(RENDER_ROOT)
FileUtils.mkdir_p(RENDER_ROOT)
FileUtils.mkdir_p(DATA_PATH.dirname)

manifest = {}
page_count_cache = {}
render_cache = {}
tmp_dirs = []

at_exit do
  tmp_dirs.each { |dir| FileUtils.rm_rf(dir) if dir && Dir.exist?(dir) }
end

routes.each do |route|
  pdf_key = route[:pdf_path].to_s
  page_count_cache[pdf_key] ||= pdf_page_count(route[:pdf_path])

  unless render_cache[pdf_key]
    tmp_dir = Pathname.new(Dir.mktmpdir("pdf-render-"))
    tmp_dirs << tmp_dir
    render_cache[pdf_key] = render_pdf(route[:pdf_path], tmp_dir, page_count_cache[pdf_key])
  end

  target_dir = RENDER_ROOT.join(route[:key])
  rendered_pages = copy_rendered_pages(render_cache[pdf_key], target_dir)

  manifest[route[:key]] = {
    "title" => route[:title],
    "section" => route[:section],
    "pdf" => route[:pdf_url],
    "pages" => rendered_pages.map { |page| relative_asset_path(page) }
  }
end

referenced_pdfs = routes.map { |route| route[:pdf_path].to_s }.uniq
unreferenced_pdfs = pdfs.reject { |pdf| referenced_pdfs.include?(pdf.to_s) }

unreferenced_pdfs.each do |pdf_path|
  page_count_cache[pdf_path.to_s] ||= pdf_page_count(pdf_path)
  relative_stem = pdf_path.relative_path_from(PDF_DIR).sub_ext("").to_s
  target_dir = RENDER_ROOT.join("_unrouted", relative_stem)
  render_pdf(pdf_path, target_dir, page_count_cache[pdf_path.to_s])
end

DATA_PATH.write(manifest.to_yaml, mode: "w", encoding: "UTF-8")

puts "Rendered #{routes.length} PDF showcase route(s)"
puts "Scanned #{pdfs.length} source PDF(s)"
puts "Wrote #{DATA_PATH.relative_path_from(ROOT)}"
